<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Template launchd job for the deterministic proactive sweep
  (proactive/sweep.ts). Copy to
  ~/Library/LaunchAgents/com.rachel.proactive-sweep.plist, replace
  __REPO_PATH__ with the absolute path to this repo checkout, then:
    launchctl load ~/Library/LaunchAgents/com.rachel.proactive-sweep.plist

  Each run is a single deterministic tick (deferred-digest flush,
  bridge-liveness via launchctl, PR-red via gh, calendar one-shot spawning)
  that exits on its own - no KeepAlive needed. All judgement about dedup,
  quiet hours, and the daily interrupt budget lives in proactive/push.ts.

  Cadence: every 30 minutes during Gary's waking hours (Ireland time),
  08:00-22:00 inclusive, EXCLUDING 22:30 which sits inside the default
  22:30-08:00 quiet window - 29 StartCalendarInterval entries. launchd
  coalesces intervals missed while the machine sleeps into one wake-time
  catch-up run.

  EnvironmentVariables/PATH is required because launchd jobs run with no
  user PATH, so tsx's `#!/usr/bin/env node` shebang can't resolve node
  (same requirement as bridge/launchd.plist).
-->
<plist version="1.0">
<dict>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>

  <key>Label</key>
  <string>com.rachel.proactive-sweep</string>

  <key>ProgramArguments</key>
  <array>
    <string>__REPO_PATH__/node_modules/.bin/tsx</string>
    <string>proactive/sweep.ts</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__REPO_PATH__</string>

  <key>StandardInPath</key>
  <string>/dev/null</string>

  <key>StartCalendarInterval</key>
